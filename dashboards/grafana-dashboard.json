{
  "__inputs": [
    {
      "name": "DS_ELASTICSEARCH",
      "label": "Elasticsearch",
      "description": "Log anomaly detection index",
      "type": "datasource",
      "pluginId": "elasticsearch",
      "pluginName": "Elasticsearch"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "elasticsearch", "name": "Elasticsearch", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Real-Time Log Anomaly Detection Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [

    {
      "id": 1,
      "title": "Total Logs Processed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["count"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "*",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": []
        }
      ],
      "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" }
    },

    {
      "id": 2,
      "title": "Total Anomalies",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["count"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "is_anomaly:true",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": []
        }
      ],
      "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" }
    },

    {
      "id": 3,
      "title": "Anomaly Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 20,
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 8 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "*",
          "timeField": "processed_at",
          "metrics": [
            { "id": "1", "type": "count" },
            {
              "id": "2",
              "type": "bucket_script",
              "pipelineVariables": [{ "name": "anomalies", "pipelineAgg": "1" }],
              "settings": { "script": "params.anomalies" }
            }
          ],
          "bucketAggs": [
            { "id": "3", "type": "date_histogram", "field": "processed_at",
              "settings": { "interval": "1m", "min_doc_count": "0" } }
          ]
        }
      ],
      "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" }
    },

    {
      "id": 4,
      "title": "Average Latency (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "*",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "avg", "field": "latency_ms" }],
          "bucketAggs": []
        }
      ],
      "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" }
    },

    {
      "id": 5,
      "title": "Active Services",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "purple", "value": null } ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "*",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "cardinality", "field": "service" }],
          "bucketAggs": []
        }
      ],
      "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" }
    },

    {
      "id": 6,
      "title": "Log Volume Over Time (Normal vs Anomaly)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 4 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Anomalies" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Normal" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "alias": "Normal",
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "is_anomaly:false",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "processed_at",
              "settings": { "interval": "30s", "min_doc_count": "0" } }
          ]
        },
        {
          "alias": "Anomalies",
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "is_anomaly:true",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "processed_at",
              "settings": { "interval": "30s", "min_doc_count": "0" } }
          ]
        }
      ],
      "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" }
    },

    {
      "id": 7,
      "title": "Anomalies by Service",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 4 },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "is_anomaly:true",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "terms", "field": "service",
              "settings": { "size": "10", "order": "desc", "orderBy": "1" } }
          ]
        }
      ],
      "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" }
    },

    {
      "id": 8,
      "title": "Average Latency by Service (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "*",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "avg", "field": "latency_ms" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "processed_at",
              "settings": { "interval": "30s", "min_doc_count": "0" } },
            { "id": "3", "type": "terms", "field": "service",
              "settings": { "size": "5", "order": "desc", "orderBy": "1" } }
          ]
        }
      ],
      "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" }
    },

    {
      "id": 9,
      "title": "Error Rate by HTTP Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 5 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx Errors" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx Errors" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "targets": [
        {
          "alias": "5xx Errors",
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "status_code:>=500",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "processed_at",
              "settings": { "interval": "30s", "min_doc_count": "0" } }
          ]
        },
        {
          "alias": "4xx Errors",
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "status_code:>=400 AND status_code:<500",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "processed_at",
              "settings": { "interval": "30s", "min_doc_count": "0" } }
          ]
        }
      ],
      "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" }
    },

    {
      "id": 10,
      "title": "Live Anomaly Log Feed",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "options": {
        "sortBy": [{ "displayName": "processed_at", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "anomaly_score" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.4 },
                    { "color": "red", "value": 0.7 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "latency_ms" },
            "properties": [{ "id": "unit", "value": "ms" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
          "query": "is_anomaly:true",
          "timeField": "processed_at",
          "metrics": [{ "id": "1", "type": "raw_data", "settings": { "size": "100" } }],
          "bucketAggs": []
        }
      ],
      "datasource": { "type": "elasticsearch", "uid": "${DS_ELASTICSEARCH}" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "_id": true, "_type": true, "_index": true, "raw_if_score": true },
            "renameByName": {
              "processed_at": "Detected At",
              "service": "Service",
              "level": "Level",
              "status_code": "Status",
              "latency_ms": "Latency",
              "anomaly_score": "Anomaly Score",
              "message": "Message"
            },
            "indexByName": {
              "processed_at": 0,
              "service": 1,
              "level": 2,
              "status_code": 3,
              "latency_ms": 4,
              "anomaly_score": 5,
              "message": 6
            }
          }
        }
      ]
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["logs", "anomaly", "kafka", "ml"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Log Anomaly Detection",
  "uid": "log-anomaly-v1",
  "version": 1
}